rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.balance is number &&
             data.createdAt is string;
    }

    function isValidTransaction(data) {
       return data.keys().hasAll(['userId', 'type', 'amount', 'status', 'timestamp']) &&
              data.userId == request.auth.uid &&
              data.type in ['exchange', 'withdraw'] &&
              data.amount is number && data.amount > 0 &&
              data.status == 'pending' &&
              data.timestamp is timestamp;
    }

    // --- Collection Matches ---

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Broad list for referral code search, filtered by client
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().balance == 0;
      allow update: if (isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'displayName', 'stats', 'referralCode', 'referredBy', 'lastIp', 'updatedAt', 'balance'])) ||
                      (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['stats'])); // Allow others to increment referral/leads counts
    }

    // Offers Collection
    match /offers/{offerId} {
      allow read: if isSignedIn() && isValidId(offerId);
      allow write: if false; // System only
    }

    // Clicks Collection
    match /clicks/{clickId} {
      allow create: if isSignedIn() && isValidId(clickId) && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && isValidId(clickId) && existing().userId == request.auth.uid;
    }

    // Views Collection
    match /views/{viewId} {
      allow create: if isSignedIn() && isValidId(viewId) && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && isValidId(viewId) && existing().userId == request.auth.uid;
    }

    // Leads Collection
    match /leads/{leadId} {
      allow read: if isSignedIn() && isValidId(leadId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // System only
    }

    // Referral Commissions
    match /referral_commissions/{commId} {
      allow read: if isSignedIn() && isValidId(commId) && existing().referrerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.referrerId == request.auth.uid;
      allow write: if false;
    }

    // Transactions Collection
    match /transactions/{transId} {
      allow get: if isSignedIn() && isValidId(transId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transId) && isValidTransaction(incoming());
      allow update, delete: if false;
    }
  }
}
